    given-names: Ahed
    email: adwansubs@icloud.com
repository-code: "https://github.com/AhedAdwan/convo-recall"
url: "https://github.com/AhedAdwan/convo-recall"
license: LicenseRef-FSL-1.1-Apache-2.0
keywords:
  - conversation-memory
  - retrieval-augmented-generation
  - sqlite
  - fts5
  - sqlite-vec
  - claude-code
  - codex
  - gemini
  - hybrid-search
